# =============================================================================
# PYMES Data Strategy - Git Ignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnpm-store/

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.uv/

# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
dist/
build/
*.egg-info/

# -----------------------------------------------------------------------------
# IDE
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.coverage
htmlcov/
.pytest_cache/
.nyc_output/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Docker volumes (local data)
# -----------------------------------------------------------------------------
docker-data/

# -----------------------------------------------------------------------------
# Prisma
# -----------------------------------------------------------------------------
# Keep migrations in git, ignore generated client
# node_modules/.prisma/ is already ignored via node_modules

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp

# -----------------------------------------------------------------------------
# Secrets (NEVER commit these)
# -----------------------------------------------------------------------------
*.pem
*.key
secrets/
credentials.json
