# Development Dockerfile for API Gateway
# Build context should be the root of the monorepo (backend/)
# docker build -f api/Dockerfile.dev -t pymes-api .

FROM node:20-alpine

WORKDIR /app

# Install pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

# Copy workspace config (from root context)
COPY package.json pnpm-workspace.yaml ./

# Copy API package files
COPY api/package.json api/

# Copy Prisma schema
COPY prisma/ prisma/

# Install all workspace dependencies from the monorepo root
RUN pnpm install

# Generate Prisma client
RUN pnpm exec prisma generate --schema=prisma/schema.prisma

# Copy API source code
COPY api/ api/

# Copy entrypoint script
COPY api/docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

# Expose port
EXPOSE 3000

# Start development server with hot reload via pnpm workspace filter
ENTRYPOINT ["/docker-entrypoint.sh"]
CMD ["pnpm", "--filter", "api", "dev"]
