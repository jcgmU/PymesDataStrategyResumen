{
  "name": "@pymes/api",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@prisma/client": "6.4.1",
    "bullmq": "5.34.8",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "helmet": "8.0.0",
    "ioredis": "5.4.2",
    "pino": "9.6.0",
    "pino-http": "10.4.0",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "9.21.0",
    "@testcontainers/postgresql": "^11.12.0",
    "@testcontainers/redis": "^11.12.0",
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/node": "22.13.5",
    "@vitest/coverage-v8": "^2.1.0",
    "@vitest/ui": "^2.1.0",
    "eslint": "9.21.0",
    "nodemon": "3.1.9",
    "prettier": "3.5.2",
    "prisma": "6.4.1",
    "testcontainers": "^11.12.0",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "typescript-eslint": "8.24.1",
    "vitest": "^2.1.0"
  }
}
